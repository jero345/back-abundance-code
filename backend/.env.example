PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
#   - URL                    → SUPABASE_URL
#   - anon / public key      → SUPABASE_ANON_KEY        (safe in frontend too)
#   - service_role secret    → SUPABASE_SERVICE_ROLE_KEY (server-only, never ship!)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PUBLIC.anon.key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SECRET.service.role.key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5000

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@abundancecode.com

# Products (in cents, used by Stripe checkout)
# Crystal Code:         $177.00 = 17700
# Crystal Code Premium: $217.00 = 21700
CRYSTAL_CODE_PRICE=17700
CRYSTAL_CODE_PREMIUM_PRICE=21700

# WooCommerce REST API v3 (optional — sync products via webhook)
WC_URL=https://shop.abundancecode.com
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=
WC_CRYSTAL_CODE_ID=0
WC_CRYSTAL_CODE_PREMIUM_ID=0

# ─────────────────────────────────────────────────────────────────────────────
# Admin
# Grant admin via Supabase SQL Editor:
#   update public.profiles set is_admin = true where email = 'you@example.com';
# ─────────────────────────────────────────────────────────────────────────────
